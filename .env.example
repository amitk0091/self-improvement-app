# Copy to .env.local and fill in. Supabase: Project Settings -> API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR-ANON-OR-PUBLISHABLE-KEY

# AI Review (server-side only). Free tiers: Groq is tried first, then Gemini, else heuristic.
GROQ_API_KEY=
GEMINI_API_KEY=
